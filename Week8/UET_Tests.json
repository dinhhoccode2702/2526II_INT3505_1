    {
      "name": "http://localhost:5000/api/users",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// 1. Kiểm tra đã tạo thành công (201 Created)\r",
              "pm.test(\"Tạo User thành công (201)\", function () {\r",
              "    pm.response.to.have.status(201);\r",
              "});\r",
              "\r",
              "// 2. LẤY ID VÀ LƯU VÀO BIẾN (Đây là phần quan trọng nhất)\r",
              "var jsonData = pm.response.json();\r",
              "if (jsonData.user_id) {\r",
              "    pm.environment.set(\"latest_user_id\", jsonData.user_id);\r",
              "    console.log(\"Đã lưu ID mới: \" + jsonData.user_id);\r",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Tự tạo số ngẫu nhiên cực lớn để tránh trùng\r",
              "var randomId = Math.floor(Math.random() * 1000000);\r",
              "pm.variables.set(\"dynamic_user_id\", randomId);\r",
              "\r",
              "// Tự tạo email ngẫu nhiên\r",
              "var randomEmail = \"user\" + randomId + \"@gmail.com\";\r",
              "pm.variables.set(\"dynamic_email\", randomEmail);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "noauth"
        },
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"user_id\": {{dynamic_user_id}},\r\n    \"name\": \"User Test\",\r\n    \"email\": \"{{dynamic_email}}\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "http://localhost:5000/api/users",
          "protocol": "http",
