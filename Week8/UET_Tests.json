            "localhost"
          ],
          "port": "5000",
          "path": [
            "api",
            "users"
          ]
        }
      },
      "response": []
    },
    {
      "name": "http://localhost:5000/api/users/lastest_user_id",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// 1. Kiểm tra tìm thấy User (200 OK)\r",
              "pm.test(\"Tìm thấy User vừa tạo (200)\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "// 2. Kiểm tra xem ID trả về có khớp với ID đã lưu không\r",
              "pm.test(\"ID trả về khớp với ID trong biến môi trường\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    var savedId = pm.environment.get(\"latest_user_id\");\r",
              "    pm.expect(jsonData.user_id).to.eql(savedId);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
